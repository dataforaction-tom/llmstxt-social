# llmstxt-social Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://postgres:dev_password@postgres/llmstxt
POSTGRES_PASSWORD=dev_password

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== API Keys =====
# Required: Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Required for paid tier: Get from https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_PUBLIC_KEY=pk_test_your-public-key-here
VITE_STRIPE_PUBLIC_KEY=pk_test_your-public-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# One-time payments kill switch. false (default) = full pipeline (enrichment
# + assessment) is free and one-time payment endpoints return 403. Monitoring
# subscriptions stay paid via Stripe regardless. Keep PAYMENTS_ENABLED and
# VITE_PAYMENTS_ENABLED in sync — the second is baked into the web build.
PAYMENTS_ENABLED=false
VITE_PAYMENTS_ENABLED=false

# Optional: Get from https://resend.com/ (for email notifications)
RESEND_API_KEY=re_your-resend-key-here

# Optional: Get from https://www.gov.uk/guidance/charity-commission-data-api
CHARITY_COMMISSION_API_KEY=your-charity-commission-key-here

# ===== Application Settings =====
SECRET_KEY=change-this-to-a-random-secret-in-production
ENVIRONMENT=development
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
WEB_DIST_DIR=/app/web/dist

# Auth cookie scope. Leave UNSET in development so the cookie is host-only on
# localhost. In production set to a leading-dot domain that covers every
# subdomain you want a single login to span (e.g. ``.good-ship.co.uk`` lets
# the same login work on both llmstxt.social and openorg.good-ship.co.uk).
# AUTH_COOKIE_DOMAIN=.good-ship.co.uk

# ===== Open Org / Murmurations =====
# Defaults point at the Murmurations *test* index until our
# open_org_profile-v0.1.0 schema PR is merged upstream. Flip these to
# production once the schema is live in the production library:
#   https://index.murmurations.network/v2
#   https://library.murmurations.network/v2
MURMURATIONS_INDEX_URL=https://test-index.murmurations.network/v2
MURMURATIONS_LIBRARY_URL=https://test-library.murmurations.network/v2

# Rate limiting (requests per day for free tier)
FREE_TIER_DAILY_LIMIT=10

# CORS origins (comma-separated, for production)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ===== Optional: Email Settings =====
# If not using Resend, configure SMTP directly
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
