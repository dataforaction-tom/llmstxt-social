{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openorg.good-ship.co.uk/schemas/org_profile/v0.1.json",
  "title": "Open Org profile",
  "description": "An organisation's profile — identity, mission, governance, and culture. Phase 1 schema v0.1.",
  "type": "object",
  "required": ["schema_version", "identity", "mission"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "open-org/v0.1"
    },
    "identity": {
      "type": "object",
      "required": ["name", "registration"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "also_known_as": {
          "type": "array",
          "items": {"type": "string"}
        },
        "registration": {
          "type": "object",
          "description": "At least one registration identifier is required.",
          "anyOf": [
            {"required": ["charity_commission_ew"]},
            {"required": ["companies_house"]},
            {"required": ["oscr"]},
            {"required": ["ccni"]},
            {"required": ["other"]}
          ],
          "properties": {
            "charity_commission_ew": {"type": "string", "pattern": "^[0-9]{6,8}(-[0-9]+)?$"},
            "companies_house": {"type": "string", "minLength": 1},
            "oscr": {"type": "string", "pattern": "^SC[0-9]{6}$"},
            "ccni": {"type": "string", "pattern": "^[0-9]{6}$"},
            "other": {"type": "string", "minLength": 1}
          }
        },
        "identifiers": {
          "type": "object",
          "properties": {
            "org_id": {"type": "string", "pattern": "^[A-Z]{2}-[A-Z]{3}-.+$"},
            "llms_txt": {"type": "string", "format": "uri"}
          }
        },
        "geography": {
          "type": "object",
          "properties": {
            "primary_area": {"type": "string", "minLength": 1},
            "primary_area_code": {"type": "string", "pattern": "^[A-Z][0-9]{8}$"},
            "operating_areas": {
              "type": "array",
              "items": {"type": "string"}
            },
            "geolocation": {
              "type": "object",
              "required": ["lat", "lon"],
              "properties": {
                "lat": {"type": "number", "minimum": -90, "maximum": 90},
                "lon": {"type": "number", "minimum": -180, "maximum": 180}
              }
            }
          }
        },
        "scale": {
          "type": "object",
          "properties": {
            "annual_income_band": {
              "type": "string",
              "enum": [
                "under_10k", "10k-100k", "100k-250k", "250k-500k",
                "500k-1m", "1m-5m", "5m-10m", "10m-100m", "over_100m"
              ]
            },
            "annual_income": {"type": "integer", "minimum": 0},
            "trustee_count": {"type": "integer", "minimum": 0},
            "staff_count": {"type": "integer", "minimum": 0},
            "volunteer_count": {"type": "integer", "minimum": 0}
          }
        },
        "website": {"type": "string", "format": "uri"},
        "founded": {"type": "string", "format": "date"},
        "contact": {
          "type": "object",
          "properties": {
            "email": {"type": "string", "format": "email"},
            "phone": {"type": "string"},
            "address": {"type": "string"},
            "postcode": {"type": "string"}
          }
        }
      }
    },
    "mission": {
      "type": "object",
      "required": ["themes"],
      "properties": {
        "summary": {"type": "string", "maxLength": 500},
        "objects": {"type": "string"},
        "theory_of_change": {"type": "string"},
        "themes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "older_people", "children_and_young_people", "families_and_carers",
              "health", "mental_health", "disability", "social_prescribing",
              "loneliness", "food_access", "housing_and_homelessness",
              "poverty_and_financial_inclusion", "community_development",
              "volunteering", "lived_experience", "education",
              "employment_and_skills", "arts_and_culture", "heritage",
              "environment_and_climate", "nature_and_biodiversity",
              "transport_and_mobility", "digital_inclusion", "civic_participation",
              "women_and_girls", "lgbtq_plus", "race_equity",
              "refugees_and_migration", "crime_and_justice", "domestic_abuse",
              "animal_welfare"
            ]
          }
        },
        "beneficiaries": {
          "type": "array",
          "items": {"type": "string"}
        },
        "programmes": {
          "description": "What the organisation actually delivers — ongoing services and specific projects. Populated from the website crawl + LLM analysis when the organisation is generated; editable by the org thereafter.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "description": {"type": "string"},
              "eligibility": {"type": "string"},
              "location": {"type": "string"}
            }
          }
        },
        "evidence_summary": {
          "description": "Lightweight Phase-1 impact stubs from CC annual return data + website extraction. Richer evidence with external links (Hypercerts at https://docs.hypercerts.org, evaluation reports, programme data feeds) is planned for a future top-level `evidence` array — Phase 4.",
          "type": "object",
          "properties": {
            "beneficiaries_served_text": {"type": "string"},
            "outcomes": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "properties": {
        "board_size": {"type": "integer", "minimum": 0},
        "accounts_filed_to": {"type": "string", "format": "date"},
        "policies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string"},
              "last_reviewed": {"type": "string", "format": "date"}
            }
          }
        }
      }
    },
    "culture": {
      "type": "object",
      "properties": {
        "narrative": {"type": "string"}
      }
    },
    "values": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
