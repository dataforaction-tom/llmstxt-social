{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openorg.good-ship.co.uk/schemas/org_strategy/v0.1.json",
  "title": "Open Org strategy",
  "description": "An organisation's strategy — priorities, tensions, learning, relationships. Phase 1 schema v0.1.",
  "type": "object",
  "required": ["schema_version", "id", "status", "themes"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "open-org-strategy/v0.1"
    },
    "id": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["draft", "active", "archived"]
    },
    "access_level": {
      "type": "string",
      "enum": ["summary_public", "full_public", "summary_private", "full_private"]
    },
    "period": {
      "type": "object",
      "properties": {
        "start": {"type": "string", "format": "date"},
        "end": {"type": "string", "format": "date"},
        "horizon": {
          "type": "string",
          "enum": ["1_year", "2_3_years", "3_5_years", "5_10_years"]
        }
      }
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "older_people", "children_and_young_people", "families_and_carers",
          "health", "mental_health", "disability", "social_prescribing",
          "loneliness", "food_access", "housing_and_homelessness",
          "poverty_and_financial_inclusion", "community_development",
          "volunteering", "lived_experience", "education",
          "employment_and_skills", "arts_and_culture", "heritage",
          "environment_and_climate", "nature_and_biodiversity",
          "transport_and_mobility", "digital_inclusion", "civic_participation",
          "women_and_girls", "lgbtq_plus", "race_equity",
          "refugees_and_migration", "crime_and_justice", "domestic_abuse",
          "animal_welfare"
        ]
      }
    },
    "summary": {"type": "string"},
    "priorities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "themes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "maturity": {
            "type": "string",
            "enum": ["seed", "emerging", "established", "mature"]
          },
          "narrative": {"type": "string"},
          "success_indicators": {
            "type": "array",
            "items": {"type": "string"}
          },
          "dependencies": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "not_doing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {"type": "string"},
          "rationale": {"type": "string"}
        }
      }
    },
    "tensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {"type": "string"},
          "narrative": {"type": "string"}
        }
      }
    },
    "learning": {
      "type": "object",
      "properties": {
        "what_changed": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["lesson"],
            "properties": {
              "lesson": {"type": "string"},
              "source": {"type": "string"}
            }
          }
        }
      }
    },
    "relationships": {
      "type": "object",
      "properties": {
        "partnerships": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string"},
              "direction": {
                "type": "string",
                "enum": ["new", "deepening", "established", "winding_down"]
              },
              "narrative": {"type": "string"}
            }
          }
        },
        "ecosystem_position": {"type": "string"},
        "community_mandate": {"type": "string"}
      }
    },
    "resource_model": {
      "type": "object",
      "properties": {
        "current_funding_mix": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 100}
        },
        "sustainability_direction": {
          "type": "string",
          "enum": ["diversifying", "concentrating", "stable", "declining"]
        },
        "resourcing_gaps": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date"],
        "properties": {
          "version": {"type": "string"},
          "date": {"type": "string", "format": "date"},
          "summary": {"type": "string"}
        }
      }
    }
  }
}
